{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "../../.",
  "testRegex": ".*\\.spec\\.ts$",
  "maxWorkers": "4",
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest"]
  },
  "moduleNameMapper": {
    "^@core/(.*)$": "<rootDir>/src/core/$1",
    "^@core$": "<rootDir>/src/core/index.ts",
    "^@config/(.*)$": "<rootDir>/src/config/$1",
    "^@config$": "<rootDir>/src/config/index.ts",
    "^@src/(.*)$": "<rootDir>/src/$1",
    "^@test/(.*)$": "<rootDir>/test/$1"
  },
  "collectCoverageFrom": ["src/**/*.(use-case).(t|j)s"],
  "coverageThreshold": {
    "global": {
      "lines": 100,
      "branches": 100
    }
  },
  "coverageDirectory": "./coverage",
  "testEnvironment": "node"
}
